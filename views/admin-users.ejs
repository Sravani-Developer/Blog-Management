<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Users</title>
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link rel="manifest" href="/manifest.json" />
    <style>
      :root {
        --bg: #f4f6fb;
        --surface: #ffffff;
        --line: #dbe2ef;
        --text: #0f1830;
        --muted: #5f7392;
        --brand: #232d91;
      }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: "Work Sans", sans-serif; background: var(--bg); color: var(--text); }

      .topbar { background: #fff; border-bottom: 1px solid var(--line); }
      .topbar-inner { max-width: 1340px; margin: 0 auto; padding: 14px 18px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
      .brand { display: inline-flex; align-items: center; gap: 10px; color: var(--text); text-decoration: none; font-size: 20px; font-weight: 800; }
      .brand .logo { color: var(--brand); display: inline-flex; }
      .admin-nav { display: flex; align-items: center; gap: 22px; margin-left: auto; }
      .admin-nav a { color: #283d61; text-decoration: none; font-weight: 500; font-size: 15px; }
      .admin-nav a.active { color: var(--brand); border-bottom: 2px solid var(--brand); padding-bottom: 8px; font-weight: 700; }
      .menu { position: relative; }
      .menu-btn { border: 0; background: transparent; color: #283d61; font-weight: 500; font-size: 15px; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; }
      .menu-list { display: none; position: absolute; right: 0; top: 26px; width: 170px; background: #fff; border: 1px solid var(--line); border-radius: 10px; box-shadow: 0 12px 24px rgba(16, 24, 40, 0.12); padding: 6px 0; z-index: 40; }
      .menu-list.open { display: block; }
      .menu-list a, .menu-list button { display: block; width: 100%; border: 0; background: transparent; text-align: left; padding: 9px 12px; color: #2d4366; font-size: 14px; cursor: pointer; }
      .menu-list a:hover, .menu-list button:hover { background: #f3f6fd; color: var(--brand); }
      .avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--brand); color: #fff; font-size: 13px; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; }

      .main { max-width: 1340px; margin: 0 auto; padding: 28px 18px 48px; }
      .head h1 { margin: 0; font-size: 42px; font-weight: 800; }
      .head p { margin: 8px 0 0; color: var(--muted); font-size: 20px; }
      .head-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 14px;
      }
      .create-btn {
        margin-top: 6px;
        background: var(--brand);
        color: #fff;
        text-decoration: none;
        border-radius: 12px;
        height: 46px;
        padding: 0 18px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        font-weight: 700;
        box-shadow: 0 8px 18px rgba(35, 45, 145, 0.2);
      }
      .table-wrap { margin-top: 18px; background: var(--surface); border: 1px solid var(--line); border-radius: 12px; overflow: hidden; }
      table { width: 100%; border-collapse: collapse; }
      thead th { text-align: left; padding: 16px; font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #4a5f7f; border-bottom: 1px solid var(--line); }
      tbody td { padding: 14px 16px; border-bottom: 1px solid #e8edf6; font-size: 16px; color: #1f324f; }
      .role { display: inline-block; border-radius: 999px; padding: 4px 10px; font-size: 12px; font-weight: 700; }
      .role.admin { background: #eef0fc; color: #232d91; }
      .role.user { background: #eef5fd; color: #24518c; }
      .actions { display: inline-flex; align-items: center; gap: 8px; }
      .icon-btn { border: 0; background: transparent; color: #8091ad; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; text-decoration: none; }
      .inline-form { display: inline-flex; margin: 0; }
      .icon-btn:hover { color: var(--brand); }
      .icon-btn.delete:hover { color: #b91c1c; }
      .foot { padding: 16px; display: flex; align-items: center; justify-content: space-between; color: #5d7191; font-size: 14px; border-top: 1px solid #edf1f8; }
      .pagination { display: flex; gap: 8px; }
      .page { width: 38px; height: 38px; border: 1px solid var(--line); border-radius: 10px; display: grid; place-items: center; color: #304667; font-size: 14px; text-decoration: none; background: #fff; }
      .page.active { background: var(--brand); color: #fff; border-color: var(--brand); }
    </style>
  </head>
  <body>
    <%- include("partials/admin-header", { activeAdminPage: "users" }) %>

    <main class="main">
      <%
        const pager = pagination || { page: 1, limit: users.length || 10, total: users.length, totalPages: 1 };
        const startRow = pager.total === 0 ? 0 : ((pager.page - 1) * pager.limit) + 1;
        const endRow = Math.min(pager.page * pager.limit, pager.total);
      %>
      <section class="head">
        <div class="head-row">
          <div>
            <h1>Users Management</h1>
            <p>Create, update, and remove platform users.</p>
          </div>
          <a class="create-btn" href="/admin/users/new">
            <span class="material-symbols-outlined">person_add</span>
            Create User
          </a>
        </div>
      </section>

      <section class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Joined</th>
              <th style="text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(user) { %>
            <tr>
              <td><%= user.name %></td>
              <td><%= user.email %></td>
              <td><span class="role <%= user.role %>"><%= user.role %></span></td>
              <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
              <td style="text-align:right;">
                <div class="actions">
                  <a class="icon-btn" href="/admin/users/<%= user._id %>/edit" title="Edit user">
                    <span class="material-symbols-outlined">edit</span>
                  </a>
                  <% if (currentUser && String(currentUser._id) === String(user._id)) { %>
                  <button class="icon-btn delete" type="button" title="You cannot delete your current admin account" disabled style="opacity:.45;cursor:not-allowed;">
                    <span class="material-symbols-outlined">delete</span>
                  </button>
                  <% } else { %>
                  <form class="inline-form" method="post" action="/admin/users/<%= user._id %>/delete" onsubmit="return confirm('Delete this user and their posts?');">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="icon-btn delete" type="submit" title="Delete user">
                      <span class="material-symbols-outlined">delete</span>
                    </button>
                  </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }); %>
            <% if (!users.length) { %>
            <tr><td colspan="5">No users found.</td></tr>
            <% } %>
          </tbody>
        </table>
        <div class="foot">
          <div>Showing <strong><%= startRow %> to <%= endRow %></strong> of <strong><%= pager.total %></strong> users</div>
          <div class="pagination">
            <% if (pager.page > 1) { %>
            <a class="page" href="/admin/users?page=<%= pager.page - 1 %>&limit=<%= pager.limit %>">‹</a>
            <% } %>
            <% for (let p = 1; p <= pager.totalPages; p++) { if (p > 5 && Math.abs(p - pager.page) > 1) continue; %>
            <a class="page <%= p === pager.page ? 'active' : '' %>" href="/admin/users?page=<%= p %>&limit=<%= pager.limit %>"><%= p %></a>
            <% } %>
            <% if (pager.page < pager.totalPages) { %>
            <a class="page" href="/admin/users?page=<%= pager.page + 1 %>&limit=<%= pager.limit %>">›</a>
            <% } %>
          </div>
        </div>
      </section>
    </main>

    <script src="/js/auth-header.js"></script>
    <script src="/sw-register.js"></script>
  </body>
</html>
