<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
      :root {
        --bg: #f4f6fb;
        --surface: #ffffff;
        --line: #dbe2ef;
        --text: #0f1830;
        --muted: #5f7392;
        --brand: #232d91;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: "Work Sans", sans-serif;
        background: var(--bg);
        color: var(--text);
      }
      .topbar { background: #fff; border-bottom: 1px solid var(--line); }
      .topbar-inner { max-width: 1340px; margin: 0 auto; padding: 14px 18px; display: flex; align-items: center; gap: 16px; }
      .brand { display: inline-flex; align-items: center; gap: 10px; color: var(--text); text-decoration: none; font-weight: 800; font-size: 20px; }
      .brand .logo { color: var(--brand); display: inline-flex; }
      .admin-nav { margin-left: auto; display: flex; align-items: center; gap: 22px; }
      .admin-nav a { color: #283d61; text-decoration: none; font-weight: 500; font-size: 15px; }
      .admin-nav a.active { color: var(--brand); border-bottom: 2px solid var(--brand); padding-bottom: 8px; font-weight: 700; }
      .menu { position: relative; }
      .menu-btn { border: 0; background: transparent; color: #283d61; font-weight: 500; font-size: 15px; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; }
      .menu-list { display: none; position: absolute; right: 0; top: 26px; width: 170px; background: #fff; border: 1px solid var(--line); border-radius: 10px; box-shadow: 0 12px 24px rgba(16, 24, 40, 0.12); padding: 6px 0; z-index: 40; }
      .menu-list.open { display: block; }
      .menu-list a, .menu-list button { display: block; width: 100%; border: 0; background: transparent; text-align: left; padding: 9px 12px; color: #2d4366; font-size: 14px; cursor: pointer; }
      .menu-list a:hover, .menu-list button:hover { background: #f3f6fd; color: var(--brand); }
      .avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--brand); color: #fff; font-size: 13px; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; }

      .main {
        max-width: 1340px;
        margin: 0 auto;
        padding: 30px 18px 46px;
      }
      .hero h1 {
        margin: 0;
        font-size: 46px;
        line-height: 1.08;
        font-weight: 800;
      }
      .hero p {
        margin: 8px 0 0;
        color: var(--muted);
        font-size: 16px;
      }

      .stats {
        margin-top: 20px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }
      .stat {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 18px;
      }
      .stat-head { display: flex; align-items: flex-start; }
      .stat-icon {
        width: 62px;
        height: 62px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        background: #eef0fc;
        color: #2a3198;
        font-size: 30px;
      }
      .stat-label {
        margin-top: 16px;
        color: #5d7191;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
        font-size: 12px;
      }
      .stat-value {
        margin-top: 4px;
        font-size: 40px;
        font-weight: 800;
      }

      .logs {
        margin-top: 22px;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 12px;
        overflow: hidden;
      }
      .logs-head {
        padding: 18px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--line);
      }
      .logs-head h2 {
        margin: 0;
        font-size: 24px;
        font-weight: 800;
        display: inline-flex;
        gap: 8px;
        align-items: center;
      }
      .logs-head a {
        color: var(--brand);
        text-decoration: none;
        font-size: 18px;
        font-weight: 700;
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      thead th {
        text-align: left;
        padding: 14px 16px;
        border-bottom: 1px solid #e8edf6;
        color: #4a5f7f;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
      }
      tbody td {
        padding: 14px 16px;
        border-bottom: 1px solid #edf1f8;
        font-size: 16px;
        color: #1f324f;
      }
      .cat {
        display: inline-block;
        border-radius: 999px;
        padding: 4px 10px;
        font-size: 12px;
        font-weight: 700;
      }
      .cat.content { background: #dbeafe; color: #1d4ed8; }
      .cat.maintenance { background: #e5e7eb; color: #475569; }
      .cat.user-management { background: #fef3c7; color: #b45309; }
      .cat.security { background: #fee2e2; color: #b91c1c; }

      .footer {
        margin: 34px auto 18px;
        max-width: 1340px;
        text-align: center;
        padding: 0 18px;
        color: #7388a8;
      }
      .footer-links {
        display: inline-flex;
        gap: 22px;
        flex-wrap: wrap;
      }
      .footer-links a {
        color: #62789a;
        text-decoration: none;
      }
      .copy {
        margin-top: 12px;
        font-size: 13px;
      }
      @media (max-width: 960px) {
        .hero h1 { font-size: 36px; }
        .hero p { font-size: 18px; }
        .stats { grid-template-columns: 1fr; }
        .logs-head h2 { font-size: 28px; }
      }
    </style>
  </head>
  <body>
    <%- include("partials/admin-header", { activeAdminPage: "dashboard" }) %>

    <main class="main">
      <section class="hero">
        <h1>Good morning, Admin</h1>
        <p>Here is what's happening with your blog today.</p>
      </section>

      <section class="stats">
        <article class="stat">
          <div class="stat-head">
            <div class="stat-icon">
              <span class="material-symbols-outlined">group</span>
            </div>
          </div>
          <div class="stat-label">Total Users</div>
          <div class="stat-value"><%= stats.totalUsers.toLocaleString() %></div>
        </article>

        <article class="stat">
          <div class="stat-head">
            <div class="stat-icon">
              <span class="material-symbols-outlined">description</span>
            </div>
          </div>
          <div class="stat-label">Total Posts</div>
          <div class="stat-value"><%= stats.totalPosts.toLocaleString() %></div>
        </article>
      </section>

      <section class="logs">
        <div class="logs-head">
          <h2><span class="material-symbols-outlined">history</span> System Logs</h2>
          <a href="/admin/posts">View All</a>
        </div>
        <table>
          <thead>
            <tr>
              <th>Activity Description</th>
              <th>Category</th>
              <th>Timestamp</th>
            </tr>
          </thead>
          <tbody>
            <% if (!logs.length) { %>
            <tr>
              <td colspan="3">No recent activity available.</td>
            </tr>
            <% } %>
            <% logs.slice(0, 6).forEach(function(log) { %>
            <tr>
              <td><%= log.message %></td>
              <td>
                <span class="cat <%= log.category.toLowerCase().replace(/\s+/g, '-') %>"><%= log.category %></span>
              </td>
              <td><%= new Date(log.time).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-links">
        <a href="/about">Privacy Policy</a>
        <a href="/about">Terms of Service</a>
        <a href="/contact">Help Center</a>
      </div>
      <div class="copy">© 2026 Blog Admin Platform. Built for professional creators.</div>
    </footer>

    <script src="/js/auth-header.js"></script>
  </body>
</html>
