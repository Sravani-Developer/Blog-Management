<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
      body { margin:0; font-family:"Work Sans",sans-serif; background:#f4f6fb; color:#12203b; }
      .topbar { background:#fff; border-bottom:1px solid #dbe2ef; }
      .topbar-inner { max-width: 1340px; margin:0 auto; padding:14px 18px; display:flex; align-items:center; gap:16px; }
      .brand { display:inline-flex; align-items:center; gap:10px; text-decoration:none; color:#15213b; font-weight:800; font-size:20px; }
      .brand .logo { color:#232d91; display:inline-flex; }
      .nav { margin-left:auto; display:flex; align-items:center; gap:22px; }
      .nav a { text-decoration:none; color:#2b3f60; font-size:15px; font-weight:500; }
      .nav a.active { color:#232d91; border-bottom:2px solid #232d91; padding-bottom:8px; font-weight:700; }
      .menu { position:relative; }
      .menu-btn { border:0; background:transparent; color:#283d61; font-size:15px; font-weight:500; cursor:pointer; display:inline-flex; align-items:center; gap:4px; }
      .menu-list { display:none; position:absolute; right:0; top:26px; width:170px; background:#fff; border:1px solid #dbe2ef; border-radius:10px; box-shadow:0 12px 24px rgba(16,24,40,.12); padding:6px 0; z-index:40; }
      .menu-list.open { display:block; }
      .menu-list a,.menu-list button { display:block; width:100%; border:0; background:transparent; text-align:left; padding:9px 12px; color:#2d4366; font-size:14px; cursor:pointer; }
      .menu-list a:hover,.menu-list button:hover { background:#f3f6fd; color:#232d91; }
      .avatar { width:34px; height:34px; border-radius:50%; background:#232d91; color:#fff; display:inline-flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; }
      .main { max-width: 1340px; margin: 0 auto; padding: 26px 18px; }
      .card { background:#fff; border:1px solid #dbe2ef; border-radius:12px; padding:20px; }
      .actions { margin-top:14px; display:flex; gap:10px; }
      .btn { background:#232d91; color:#fff; text-decoration:none; border-radius:10px; padding:10px 14px; font-weight:700; }
      .btn.alt { background:#fff; border:1px solid #dbe2ef; color:#2d4366; }
    </style>
  </head>
  <body>
    <%- include("partials/auth-header", { activePage: "dashboard", navClass: "nav", showSearch: false }) %>
    <main class="main">
      <section class="card">
        <h1>Welcome, <%= currentUser ? currentUser.name : "User" %></h1>
        <p>Manage your own posts from your dashboard.</p>
        <div class="actions">
          <a class="btn" href="/me/posts">My Posts</a>
          <% if (currentUser && currentUser.role === "admin") { %>
          <a class="btn alt" href="/admin/posts">Admin Posts</a>
          <% } %>
        </div>
      </section>
    </main>
    <script src="/js/auth-header.js"></script>
  </body>
</html>
