<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password</title>
    <link rel="stylesheet" href="/css/platform-pages.css" />
    <style>
      .field-error {
        display: none;
        color: #b91c1c;
        font-size: 13px;
        margin-top: 6px;
      }
    </style>
  </head>
  <body class="platform-body forgot-page login-page">
    <%- include("partials/public-header", { activePage: "login" }) %>

    <main class="platform-main">
      <div class="auth-card-wrap">
        <div class="auth-card">
          <div class="auth-pattern">
            <div class="auth-lock">
              <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                  d="M17 9h-1V7a4 4 0 10-8 0v2H7a2 2 0 00-2 2v8a2 2 0 002 2h10a2 2 0 002-2v-8a2 2 0 00-2-2zm-7-2a2 2 0 114 0v2h-4V7z"
                ></path>
              </svg>
            </div>
          </div>
          <div class="auth-content forgot-content">
            <h1 class="forgot-title">Reset Your Password</h1>
            <p class="forgot-subtitle">
              Enter your email address and set a new password to reset your account password.
            </p>

            <div id="resetError" class="auth-error" style="display:none;color:#b91c1c;margin-bottom:12px;"></div>

            <form id="forgotPasswordPageForm">
              <div class="form-group">
                <label class="form-label">Email Address</label>
                <div class="input-password-wrap">
                  <input class="form-control platform-input input-with-left-icon" id="resetEmail" name="email" type="email" placeholder="name@company.com" required />
                  <span class="login-input-icon">
                    <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M3 5h18v14H3z"></path>
                      <path d="M3 7l9 7 9-7"></path>
                    </svg>
                  </span>
                </div>
                <div id="emailError" class="field-error"></div>
              </div>

              <div class="form-group input-password-wrap">
                <label class="form-label">New Password</label>
                <input class="form-control platform-input input-with-left-icon input-with-right-icon" id="newPassword" name="newPassword" type="password" placeholder="Minimum 8 characters" minlength="8" required />
                <span class="login-input-icon">
                  <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="5" y="11" width="14" height="10" rx="2"></rect>
                    <path d="M8 11V8a4 4 0 018 0v3"></path>
                  </svg>
                </span>
                <button class="toggle-password" type="button" id="toggleResetPassword" aria-label="Toggle password visibility">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                </button>
                <div id="newPasswordError" class="field-error"></div>
              </div>

              <button class="btn-platform forgot-submit" type="submit">Reset Password <span aria-hidden="true">→</span></button>
            </form>

            <div class="forgot-divider"></div>
            <div class="forgot-back-row">
              <a href="/login">← Back to Login</a>
            </div>
          </div>
        </div>

        <div class="platform-footer forgot-footer-links">
          <div class="platform-links">
            <a href="/contact">Need Help?</a>
            <a href="#" onclick="return false;">Privacy Policy</a>
            <a href="/contact">Contact Support</a>
          </div>
        </div>
      </div>
    </main>

    <script>
      document.getElementById("toggleResetPassword").addEventListener("click", () => {
        const input = document.getElementById("newPassword");
        input.type = input.type === "password" ? "text" : "password";
      });

      document.getElementById("forgotPasswordPageForm").addEventListener("submit", async (e) => {
        e.preventDefault();
        const errorBox = document.getElementById("resetError");
        const emailError = document.getElementById("emailError");
        const newPasswordError = document.getElementById("newPasswordError");
        errorBox.style.display = "none";
        [emailError, newPasswordError].forEach((el) => {
          el.style.display = "none";
          el.textContent = "";
        });

        const payload = {
          email: document.getElementById("resetEmail").value.trim(),
          newPassword: document.getElementById("newPassword").value
        };

        const res = await fetch("/auth/forgot-password", {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify(payload)
        });
        const body = await res.json();

        errorBox.style.display = "block";
        if (!res.ok) {
          if (body.details && typeof body.details === "object") {
            if (body.details.email) {
              emailError.style.display = "block";
              emailError.textContent = body.details.email;
            }
            if (body.details.newPassword) {
              newPasswordError.style.display = "block";
              newPasswordError.textContent = body.details.newPassword;
            }
          }
          errorBox.style.color = "#b91c1c";
          errorBox.textContent = body.error || "Password reset failed";
          return;
        }

        errorBox.style.color = "#166534";
        errorBox.textContent = "Password reset successful. Redirecting to login...";
        setTimeout(() => {
          window.location.href = "/login";
        }, 800);
      });
    </script>
  </body>
</html>
