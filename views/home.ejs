<!DOCTYPE html>
<html class="light" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>BlogPlatform - Home</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#1a227f",
              "background-light": "#f6f6f8",
              "background-dark": "#121320"
            },
            fontFamily: {
              display: ["Work Sans", "sans-serif"]
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px"
            }
          }
        }
      };
    </script>
    <link rel="manifest" href="/manifest.json" />
  </head>
  <body class="font-display bg-background-light text-slate-900 transition-colors duration-200">
    <%
      const heroPost = (featured && featured.length) ? featured[0] : ((recent && recent.length) ? recent[0] : null);
      const recentGrid = (recent || []).slice(0, 4);
      const recentSidebar = (recent || []).slice(0, 3);
      const categories = (categoryCounts || []).map(function (row) {
        return { name: row._id || "Code Quality", count: row.count || 0 };
      });
      const profileInitial = currentUser && currentUser.name ? currentUser.name.trim().charAt(0).toUpperCase() : "U";
      const defaultPostImage = "https://images.unsplash.com/photo-1518773553398-650c184e0bb3?auto=format&fit=crop&w=1800&q=80";
      const heroImage = heroPost && heroPost.featuredImage ? heroPost.featuredImage : defaultPostImage;
      const heroLoopPosts = (featured || []).map(function (p) {
        return {
          id: p._id,
          title: p.title,
          content: p.content,
          image: p.featuredImage || defaultPostImage
        };
      });
    %>

    <header class="sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-slate-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a class="inline-flex items-center gap-2 text-primary no-underline" href="/">
            <span class="inline-flex" aria-hidden="true">
              <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor">
                <path d="M4 4h8v8H4zM12 12h8v8h-8zM4 14h6v6H4zM14 4h6v6h-6z"></path>
              </svg>
            </span>
            <span class="text-xl font-bold tracking-tight">Blog Platform</span>
          </a>
          <nav class="hidden md:flex items-center gap-8">
            <a class="text-sm font-medium hover:text-primary transition-colors" href="/">Home</a>
            <% if (!currentUser) { %>
            <a class="text-sm font-medium hover:text-primary transition-colors" href="/login">Login</a>
            <a class="bg-primary text-white px-5 py-2 rounded-lg text-sm font-bold hover:bg-opacity-90 transition-all shadow-md shadow-primary/20" href="/register">Register</a>
            <% } else { %>
            <a class="text-sm font-medium hover:text-primary transition-colors" href="/me/posts">Dashboard</a>
            <div class="relative" id="settingsMenu">
              <button id="settingsToggle" class="text-sm font-medium hover:text-primary transition-colors inline-flex items-center gap-1" type="button" aria-haspopup="true" aria-expanded="false">
                <span class="material-symbols-outlined text-base">settings</span> Settings
              </button>
              <div id="settingsDropdown" class="hidden absolute right-0 mt-2 w-44 bg-white border border-slate-200 rounded-lg shadow-lg py-2 z-50">
                <% if (currentUser.role === "admin") { %>
                <a class="block px-3 py-2 text-sm text-slate-700 hover:bg-slate-100" href="/admin/dashboard">Admin Panel</a>
                <% } %>
                <a class="block px-3 py-2 text-sm text-slate-700 hover:bg-slate-100" href="/about">About</a>
                <a class="block px-3 py-2 text-sm text-slate-700 hover:bg-slate-100" href="/contact">Contact Us</a>
                <button class="logout-action w-full text-left px-3 py-2 text-sm text-slate-700 hover:bg-slate-100">Logout</button>
              </div>
            </div>
            <a class="text-sm font-medium hover:text-primary transition-colors inline-flex items-center" href="/me" title="Profile">
              <span class="w-8 h-8 rounded-full bg-primary text-white inline-flex items-center justify-center text-xs font-bold"><%= profileInitial %></span>
            </a>
            <% } %>
          </nav>
          <div class="md:hidden flex items-center">
            <span class="material-symbols-outlined">menu</span>
          </div>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <section class="mb-12">
        <span class="sr-only">Featured Posts</span>
        <div class="relative group overflow-hidden rounded-xl bg-slate-900 aspect-[21/9]">
          <div id="heroBg" class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style="background-image:url('<%= heroImage %>')"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-8 md:p-12 max-w-3xl">
            <span class="inline-block px-3 py-1 rounded-full bg-primary text-white text-xs font-bold uppercase tracking-wider mb-4">Featured</span>
            <h1 id="heroTitle" class="text-2xl md:text-4xl font-black text-white leading-tight mb-4">
              <%= heroPost ? heroPost.title : "The Future of Database Scalability: Handling Petabytes with Zero Downtime" %>
            </h1>
            <p id="heroContent" class="text-slate-200 text-base md:text-lg mb-6 line-clamp-2">
              <%= heroPost ? heroPost.content : "Discover how modern distributed systems are evolving to handle immense data loads while maintaining strict consistency models and high availability." %>
            </p>
            <a id="heroLink" class="bg-primary text-white px-8 py-3 rounded-lg font-bold inline-flex items-center gap-2 hover:translate-x-1 transition-all <%= heroPost ? '' : 'hidden' %>" href="<%= heroPost ? '/posts/' + heroPost._id : '#' %>">
              Read More <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
        </div>
      </section>

      <div class="flex flex-col lg:flex-row gap-12">
        <div class="lg:w-2/3">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-xl md:text-2xl font-bold tracking-tight"><%= activeCategory ? (activeCategory + " Posts") : "Recent Blog Posts" %></h2>
            <div class="flex gap-2">
              <button class="p-2 rounded-lg border border-slate-200 hover:bg-slate-100">
                <span class="material-symbols-outlined text-sm">grid_view</span>
              </button>
              <button class="p-2 rounded-lg border border-slate-200 hover:bg-slate-100">
                <span class="material-symbols-outlined text-sm">view_list</span>
              </button>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <% if (!recentGrid.length) { %>
            <div class="md:col-span-2 bg-white border border-slate-200 rounded-xl p-6">
              <p class="text-slate-600">No recent posts available.</p>
            </div>
            <% } %>
            <% recentGrid.forEach(function(post, idx) { %>
            <article class="group flex flex-col bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow">
              <div class="aspect-video relative overflow-hidden">
                <img class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-110" src="<%= post.featuredImage || defaultPostImage %>" alt="<%= post.title %>" />
                <div class="absolute top-4 left-4">
                  <span class="bg-white/90 backdrop-blur px-2 py-1 rounded text-[10px] font-bold text-primary uppercase">
                    <%= post.category || post.autoCategory || (idx % 2 === 0 ? "Code Quality" : "Frontend") %>
                  </span>
                </div>
              </div>
              <div class="p-5 flex flex-col flex-1">
                <div class="flex items-center gap-2 text-xs text-slate-500 mb-3">
                  <span class="font-semibold text-slate-900"><%= post.author ? post.author.name : "Author" %></span>
                  <span>•</span>
                  <span><%= new Date(post.createdAt).toLocaleDateString() %></span>
                </div>
                <h3 class="text-lg md:text-xl font-bold mb-2 group-hover:text-primary transition-colors"><%= post.title %></h3>
                <p class="text-slate-600 text-sm mb-4 flex-1 line-clamp-3"><%= post.content %></p>
                <a class="inline-flex items-center gap-1 text-sm font-bold text-primary group/link" href="/posts/<%= post._id %>">
                  Read Post
                  <span class="material-symbols-outlined text-sm transition-transform group-hover/link:translate-x-1">arrow_right_alt</span>
                </a>
              </div>
            </article>
            <% }); %>
          </div>

          <div class="mt-12 flex justify-center">
            <button class="px-8 py-3 border-2 border-primary text-primary font-bold rounded-lg hover:bg-primary hover:text-white transition-all">
              Load More Articles
            </button>
          </div>
        </div>

        <aside class="lg:w-1/3 flex flex-col gap-10">
          <div class="relative">
            <input class="w-full bg-white border-slate-200 rounded-lg pl-10 pr-4 py-3 focus:ring-2 focus:ring-primary focus:border-primary" placeholder="Search articles..." type="text" />
            <span class="material-symbols-outlined absolute left-3 top-3.5 text-slate-400">search</span>
          </div>

          <div>
            <h3 class="text-base md:text-lg font-bold mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-primary">category</span> Categories
            </h3>
            <div class="flex flex-col gap-1">
              <% if (activeCategory) { %>
              <a class="flex items-center justify-between p-3 rounded-lg hover:bg-white transition-colors group" href="/">
                <span class="text-sm font-medium">All Categories</span>
                <span class="bg-slate-100 text-slate-500 text-[10px] font-bold px-2 py-0.5 rounded-full">Reset</span>
              </a>
              <% } %>
              <% if (!categories.length) { %>
              <div class="p-3 rounded-lg bg-white border border-slate-200 text-sm text-slate-500">No categories yet</div>
              <% } %>
              <% categories.forEach(function (cat, idx) { %>
              <a
                class="flex items-center justify-between p-3 rounded-lg transition-colors group <%= activeCategory === cat.name ? 'bg-white border border-slate-200 hover:border-primary' : 'hover:bg-white' %>"
                href="/?category=<%= encodeURIComponent(cat.name) %>"
              >
                <span class="text-sm font-medium"><%= cat.name %></span>
                <span class="<%= activeCategory === cat.name ? 'bg-primary/10 text-primary' : 'bg-slate-100 text-slate-500' %> text-[10px] font-bold px-2 py-0.5 rounded-full"><%= cat.count %></span>
              </a>
              <% }); %>
            </div>
          </div>

          <div>
            <h3 class="text-base md:text-lg font-bold mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-primary">history</span> Recent Posts
            </h3>
            <div class="flex flex-col gap-6">
              <% if (!recentSidebar.length) { %>
              <p class="text-sm text-slate-500">Recent Posts are not available.</p>
              <% } %>
              <% recentSidebar.forEach(function(post, idx) { %>
              <a class="flex gap-4 group cursor-pointer" href="/posts/<%= post._id %>">
                <div class="size-16 shrink-0 overflow-hidden rounded-lg">
                  <img class="w-full h-full object-cover transition-transform group-hover:scale-110" src="<%= post.featuredImage || defaultPostImage %>" alt="<%= post.title %>" />
                </div>
                <div>
                  <h4 class="text-sm font-bold leading-snug group-hover:text-primary transition-colors line-clamp-2"><%= post.title %></h4>
                  <span class="text-[10px] text-slate-400 font-medium"><%= new Date(post.createdAt).toLocaleDateString() %></span>
                </div>
              </a>
              <% }); %>
            </div>
          </div>

          <div class="bg-primary p-6 rounded-xl text-white shadow-lg shadow-primary/30 relative overflow-hidden">
            <div class="absolute -right-10 -top-10 text-white/10">
              <span class="material-symbols-outlined text-[120px]">mail</span>
            </div>
            <h3 class="text-lg md:text-xl font-bold mb-2">Weekly Newsletter</h3>
            <p class="text-white/80 text-sm mb-6">Get the latest developer trends and tutorials delivered to your inbox every Monday.</p>
            <form class="flex flex-col gap-3">
              <input class="bg-white/10 border-white/20 text-white placeholder:text-white/50 rounded-lg p-3 focus:ring-2 focus:ring-white/50 focus:border-transparent text-sm" placeholder="you@example.com" type="email" />
              <button class="bg-white text-primary font-bold py-3 rounded-lg hover:bg-slate-100 transition-colors shadow-lg">Subscribe Now</button>
            </form>
          </div>
        </aside>
      </div>
    </main>

    <footer class="bg-white border-t border-slate-200 pt-16 pb-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
          <div class="flex flex-col gap-4">
            <div class="flex items-center gap-2">
              <div class="text-primary">
                <span class="material-symbols-outlined text-3xl font-bold">rocket_launch</span>
              </div>
              <span class="text-xl font-bold tracking-tight text-primary">BlogPlatform</span>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed">
              Empowering developers with high-quality insights, tutorials, and deep dives into modern engineering practices.
            </p>
          </div>
          <div>
            <h4 class="text-sm font-bold uppercase tracking-widest mb-6">Resources</h4>
            <ul class="flex flex-col gap-4 text-sm text-slate-500">
              <li><a class="hover:text-primary transition-colors" href="#">Documentation</a></li>
              <li><a class="hover:text-primary transition-colors" href="#">Cheat Sheets</a></li>
              <li><a class="hover:text-primary transition-colors" href="#">Community Forum</a></li>
              <li><a class="hover:text-primary transition-colors" href="#">Newsletter Archive</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-bold uppercase tracking-widest mb-6">Company</h4>
            <ul class="flex flex-col gap-4 text-sm text-slate-500">
              <li><a class="hover:text-primary transition-colors" href="/about">About Us</a></li>
              <li><a class="hover:text-primary transition-colors" href="#">Careers</a></li>
              <li><a class="hover:text-primary transition-colors" href="#">Privacy Policy</a></li>
              <li><a class="hover:text-primary transition-colors" href="#">Terms of Service</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-bold uppercase tracking-widest mb-6">Get in Touch</h4>
            <p class="text-sm text-slate-500 mb-4">Have questions? Reach out to our team.</p>
            <a class="text-primary font-bold text-sm hover:underline" href="mailto:hello@blogplatform.com">hello@blogplatform.com</a>
          </div>
        </div>
        <div class="border-t border-slate-100 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-[10px] uppercase tracking-widest font-bold text-slate-400">© 2026 BlogPlatform Inc. All rights reserved.</p>
          <div class="flex items-center gap-6">
            <button class="text-xs font-bold text-slate-500 hover:text-primary transition-colors flex items-center gap-1">
              <span class="material-symbols-outlined text-sm">language</span> English
            </button>
            <button class="text-xs font-bold text-slate-500 hover:text-primary transition-colors flex items-center gap-1">
              <span class="material-symbols-outlined text-sm">dark_mode</span> Dark Mode
            </button>
          </div>
        </div>
      </div>
    </footer>

    <script src="/sw-register.js"></script>
    <script>
      (function () {
        const menuWrap = document.getElementById("settingsMenu");
        const toggle = document.getElementById("settingsToggle");
        const dropdown = document.getElementById("settingsDropdown");
        if (!menuWrap || !toggle || !dropdown) return;

        function closeMenu() {
          dropdown.classList.add("hidden");
          toggle.setAttribute("aria-expanded", "false");
        }

        toggle.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          const open = dropdown.classList.contains("hidden");
          dropdown.classList.toggle("hidden", !open);
          toggle.setAttribute("aria-expanded", open ? "true" : "false");
        });

        dropdown.addEventListener("click", (e) => e.stopPropagation());
        document.addEventListener("click", closeMenu);
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") closeMenu();
        });
      })();

      document.querySelectorAll(".logout-action").forEach((btn) => {
        btn.addEventListener("click", async () => {
          await fetch("/auth/logout", { method: "POST", headers: { Accept: "application/json" } });
          window.location.href = "/";
        });
      });

      (function () {
        const heroPosts = <%- JSON.stringify(heroLoopPosts).replace(/</g, "\\u003c") %>;
        if (!Array.isArray(heroPosts) || heroPosts.length <= 1) return;

        const heroBg = document.getElementById("heroBg");
        const heroTitle = document.getElementById("heroTitle");
        const heroContent = document.getElementById("heroContent");
        const heroLink = document.getElementById("heroLink");
        if (!heroBg || !heroTitle || !heroContent || !heroLink) return;

        let idx = 0;
        setInterval(() => {
          idx = (idx + 1) % heroPosts.length;
          const post = heroPosts[idx];
          heroBg.style.backgroundImage = `url('${post.image}')`;
          heroTitle.textContent = post.title;
          heroContent.textContent = post.content;
          heroLink.href = `/posts/${post.id}`;
          heroLink.classList.remove("hidden");
        }, 5000);
      })();
    </script>
  </body>
</html>
