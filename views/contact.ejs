<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact - Blog Platform</title>
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
      :root {
        --bg: #f4f6fb;
        --surface: #ffffff;
        --line: #dbe2ef;
        --text: #0f1830;
        --muted: #5f7392;
        --brand: #232d91;
      }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: "Work Sans", sans-serif; background: var(--bg); color: var(--text); }

      .platform-header { background: #fff; border-bottom: 1px solid var(--line); }
      .platform-header-inner { max-width: 1340px; margin: 0 auto; padding: 12px 18px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
      .platform-brand { display: inline-flex; align-items: center; gap: 10px; color: var(--text); text-decoration: none; font-weight: 800; font-size: 20px; }
      .platform-brand svg { color: var(--brand); }
      .platform-nav { display: inline-flex; align-items: center; gap: 16px; }
      .platform-nav a { color: #283d61; text-decoration: none; font-weight: 500; font-size: 15px; }
      .platform-nav-active { color: var(--brand) !important; font-weight: 700 !important; }

      .topbar { background: #fff; border-bottom: 1px solid var(--line); }
      .topbar-inner { max-width: 1340px; margin: 0 auto; padding: 14px 18px; display: flex; align-items: center; gap: 16px; }
      .brand { display: inline-flex; align-items: center; gap: 10px; color: var(--text); text-decoration: none; font-weight: 800; font-size: 20px; }
      .brand .logo { color: var(--brand); display: inline-flex; }
      .nav, .admin-nav { margin-left: auto; display: flex; align-items: center; gap: 22px; }
      .nav a, .admin-nav a { text-decoration: none; color: #283d61; font-weight: 500; font-size: 15px; }
      .nav a.active, .admin-nav a.active { color: var(--brand); border-bottom: 2px solid var(--brand); padding-bottom: 8px; font-weight: 700; }
      .menu { position: relative; }
      .menu-btn { border: 0; background: transparent; color: #283d61; font-weight: 500; font-size: 15px; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; }
      .menu-list { display: none; position: absolute; right: 0; top: 26px; width: 170px; background: #fff; border: 1px solid var(--line); border-radius: 10px; box-shadow: 0 12px 24px rgba(16,24,40,.12); padding: 6px 0; z-index: 40; }
      .menu-list.open { display: block; }
      .menu-list a, .menu-list button { display: block; width: 100%; border: 0; background: transparent; text-align: left; padding: 9px 12px; color: #2d4366; font-size: 14px; cursor: pointer; }
      .menu-list a:hover, .menu-list button:hover { background: #f3f6fd; color: var(--brand); }
      .avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--brand); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; }

      .container { max-width: 1340px; margin: 0 auto; padding: 28px 18px 44px; }
      .hero h1 { margin: 0; font-size: 52px; line-height: 1.05; font-weight: 800; }
      .hero p { margin: 14px 0 0; color: var(--muted); font-size: 18px; max-width: 720px; line-height: 1.7; }

      .grid { margin-top: 26px; display: grid; grid-template-columns: 1.35fr .9fr; gap: 22px; align-items: start; }
      .card { background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 22px; }
      .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
      .field { margin-bottom: 14px; }
      label { display: block; font-weight: 700; font-size: 14px; margin-bottom: 7px; color: #1f324f; }
      input, textarea {
        width: 100%;
        border: 1px solid #c7d2e6;
        border-radius: 10px;
        background: #f8faff;
        padding: 12px 14px;
        font-size: 15px;
        color: #253a5b;
      }
      textarea { min-height: 160px; resize: vertical; }
      .btn {
        margin-top: 4px;
        border: 0;
        background: var(--brand);
        color: #fff;
        border-radius: 10px;
        padding: 12px 18px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        box-shadow: 0 8px 18px rgba(35,45,145,.22);
      }
      .msg { display:none; margin-bottom:12px; padding:10px 12px; border-radius:8px; font-size:14px; }
      .msg.ok { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }

      .side h2 { margin: 0 0 16px; font-size: 22px; font-weight: 800; }
      .contact-item { display: flex; gap: 12px; margin-bottom: 16px; }
      .contact-icon { width: 46px; height: 46px; border-radius: 10px; background: #eef1fb; color: var(--brand); display: grid; place-items: center; }
      .contact-item h3 { margin: 0 0 4px; font-size: 16px; font-weight: 700; }
      .contact-item p { margin: 0; color: #5f7392; line-height: 1.55; }
      .map-box {
        margin-top: 10px;
        height: 240px;
        border-radius: 12px;
        border: 1px solid #d8dfec;
        background:
          linear-gradient(180deg, rgba(230,235,247,.6), rgba(230,235,247,.6)),
          url('https://images.unsplash.com/photo-1524661135-423995f22d0b?auto=format&fit=crop&w=1200&q=80') center/cover no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .map-btn {
        background: #fff;
        color: #1f2d46;
        text-decoration: none;
        border-radius: 999px;
        padding: 11px 16px;
        font-weight: 700;
        display: inline-flex;
        gap: 8px;
        align-items: center;
        box-shadow: 0 8px 18px rgba(16,24,40,.12);
      }
      .social { margin-top: 18px; padding-top: 16px; border-top: 1px solid #e8edf6; }
      .social h4 { margin: 0 0 12px; color: #7a8eab; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; }
      .social-row { display: flex; gap: 10px; }
      .social-pill { width: 36px; height: 36px; border-radius: 50%; border: 1px solid var(--line); background: #fff; display: grid; place-items: center; color: #5f7392; }

      .footer {
        border-top: 1px solid var(--line);
        padding: 14px 18px;
        background: #fff;
      }
      .footer-inner {
        max-width: 1340px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        color: #8a9cb7;
        font-size: 13px;
      }
      .footer-links { display: inline-flex; gap: 14px; flex-wrap: wrap; }
      .footer-links a { color: #62789a; text-decoration: none; }

      @media (max-width: 1024px) {
        .grid { grid-template-columns: 1fr; }
      }
      @media (max-width: 640px) {
        .hero h1 { font-size: 34px; }
        .hero p { font-size: 16px; }
        .form-grid { grid-template-columns: 1fr; }
        .footer-inner { flex-direction: column; align-items: flex-start; }
      }
    </style>
  </head>
  <body>
    <% if (currentUser && currentUser.role === "admin") { %>
      <%- include("partials/admin-header", { activeAdminPage: "" }) %>
    <% } else if (currentUser) { %>
      <%- include("partials/auth-header", { activePage: "", navClass: "nav", showSearch: false }) %>
    <% } else { %>
      <%- include("partials/public-header", { activePage: "" }) %>
    <% } %>

    <main class="container">
      <section class="hero">
        <h1>Get in Touch</h1>
        <p>
          Have a question or just want to say hello? We'd love to hear from you.
          Our team typically responds within 24 hours.
        </p>
      </section>

      <section class="grid">
        <div class="card">
          <div id="contactMsg" class="msg ok">Thanks for your message. We will get back to you soon.</div>
          <form id="contactForm">
            <div class="form-grid">
              <div class="field">
                <label for="name">Name</label>
                <input id="name" placeholder="John Doe" required />
              </div>
              <div class="field">
                <label for="email">Email</label>
                <input id="email" type="email" placeholder="john@example.com" required />
              </div>
            </div>
            <div class="field">
              <label for="subject">Subject</label>
              <input id="subject" placeholder="How can we help?" required />
            </div>
            <div class="field">
              <label for="message">Message</label>
              <textarea id="message" placeholder="Your message here..." required></textarea>
            </div>
            <button class="btn" type="submit">Send Message &nbsp;></button>
          </form>
        </div>

        <aside class="side">
          <h2>Quick Contact</h2>
          <div class="contact-item">
            <div class="contact-icon"><span class="material-symbols-outlined">mail</span></div>
            <div>
              <h3>Email Us</h3>
              <p>hello@blogplatform.com</p>
              <p>support@blogplatform.com</p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><span class="material-symbols-outlined">call</span></div>
            <div>
              <h3>Call Us</h3>
              <p>+1 (555) 000-0000</p>
              <p>Mon - Fri, 9am - 5pm EST</p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><span class="material-symbols-outlined">location_on</span></div>
            <div>
              <h3>Our Office</h3>
              <p>123 Blog Lane, Tech City</p>
              <p>San Francisco, CA 94103</p>
            </div>
          </div>

          <div class="map-box">
            <a class="map-btn" href="https://maps.google.com" target="_blank" rel="noreferrer">
              <span class="material-symbols-outlined">map</span>
              View on Google Maps
            </a>
          </div>

          <div class="social">
            <h4>Follow Us</h4>
            <div class="social-row">
              <span class="social-pill"><span class="material-symbols-outlined" style="font-size:18px;">share</span></span>
              <span class="social-pill"><span class="material-symbols-outlined" style="font-size:18px;">photo_camera</span></span>
              <span class="social-pill"><span class="material-symbols-outlined" style="font-size:18px;">rss_feed</span></span>
            </div>
          </div>
        </aside>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div style="display:flex;align-items:center;gap:10px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="color:#232d91"><path d="M4 4h8v8H4zM12 12h8v8h-8zM4 14h6v6H4zM14 4h6v6h-6z"/></svg>
          <strong style="color:#62789a;">Blog Platform</strong>
        </div>
        <div class="footer-links">
          <a href="/about">Privacy Policy</a>
          <a href="/about">Terms of Service</a>
          <a href="/about">Cookie Policy</a>
        </div>
        <div>© 2026 Blog Platform. All rights reserved.</div>
      </div>
    </footer>

    <script>
      document.getElementById("contactForm").addEventListener("submit", function (e) {
        e.preventDefault();
        const msg = document.getElementById("contactMsg");
        msg.style.display = "block";
        e.target.reset();
      });
    </script>
    <% if (currentUser) { %><script src="/js/auth-header.js"></script><% } %>
  </body>
</html>
